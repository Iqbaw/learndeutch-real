# ============================================================
# DeepSeek AI configuration
# Copy this file to ".env.local" and fill in your real key.
# These variables are read ONLY on the server (API routes),
# so the key is never exposed to the browser.
# ============================================================

# Your DeepSeek API key (required to enable AI features).
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Model to use. DeepSeek V4 options:
#   deepseek-v4-flash  -> fast & cheap, great for question/lesson generation (default)
#   deepseek-v4-pro    -> highest quality reasoning
# Legacy aliases deepseek-chat / deepseek-reasoner also still work for now.
DEEPSEEK_MODEL=deepseek-v4-flash

# API base URL (OpenAI-compatible). Usually no need to change this.
DEEPSEEK_BASE_URL=https://api.deepseek.com
